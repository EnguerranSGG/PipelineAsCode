pipeline {
  agent any

  options {
    timestamps()
  }

  environment {
    CI = "true"
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Install') {
      steps {
        dir('pipeline-as-code') {
          sh 'npm ci'
        }
      }
    }

    stage('Lint') {
      steps {
        dir('pipeline-as-code') {
          sh 'npm run lint'
        }
      }
    }

    stage('Build') {
      steps {
        dir('pipeline-as-code') {
          sh 'npm run build'
        }
      }
    }

    stage('Deploy Heroku') {
      steps {
        withCredentials([string(credentialsId: 'HEROKU_API_KEY', variable: 'HEROKU_TOKEN')]) {
          sh '''
            set -e

            # On pousse la branche buildée vers Heroku (branche main côté Heroku)
            # IMPORTANT : on pousse via HTTPS avec token, sans afficher le token.
            git remote remove heroku || true
            git remote add heroku https://heroku:$HEROKU_TOKEN@git.heroku.com/$HEROKU_APP.git

            # On pousse la branche "develop" du repo vers "main" sur Heroku
            git push heroku HEAD:main --force
          '''
        }
      }
    }     
  }       

  post {
    always {
      echo "Pipeline finished."
    }
  }
}